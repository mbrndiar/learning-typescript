{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": [
    "lessons/**/*.ts",
    "exercises/**/*.ts",
    "project/**/*.ts",
    "capstones/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "lessons/13_deno_runtime/**",
    "lessons/14_bun_runtime/**",
    "exercises/13_deno_runtime/**",
    "exercises/14_bun_runtime/**",
    "project/task-deno/**",
    "project/task-bun/**",
    "capstones/idiomatic/starter/deno/**",
    "capstones/idiomatic/starter/bun/**",
    "capstones/idiomatic/solution/deno/**",
    "capstones/idiomatic/solution/bun/**",
    "capstones/idiomatic/tests/deno/**",
    "capstones/idiomatic/tests/bun/**",
    "scripts/*deno*.ts",
    "scripts/*bun*.ts"
  ]
}
