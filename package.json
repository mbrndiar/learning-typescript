{
  "name": "learning-typescript-course",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lesson": "tsx",
    "course": "npm run course:node",
    "course:node": "tsx scripts/run-node-course.ts",
    "course:deno": "deno task course",
    "course:bun": "bun run scripts/run-bun-course.ts",
    "portability": "tsx scripts/runtime-conformance.ts && tsx scripts/idiomatic-cli-conformance.ts",
    "portability:tasks": "tsx scripts/tasks-runtime-conformance.ts && deno run --lock=deno.lock scripts/tasks-runtime-conformance.ts && bun run scripts/tasks-runtime-conformance.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "npm run typecheck:node",
    "typecheck:node": "tsc -p tsconfig.node.json",
    "typecheck:tasks:node": "tsc -p tsconfig.tasks.node.json",
    "typecheck:capstones:node": "tsc -p tsconfig.capstones.node.json",
    "typecheck:bun": "tsc -p tsconfig.bun.json",
    "typecheck:tasks:bun": "tsc -p tsconfig.tasks.bun.json",
    "links": "tsx scripts/check-links.ts",
    "openapi:tasks": "tsx scripts/validate-tasks-openapi.ts",
    "test": "npm run test:node",
    "test:node": "tsx scripts/run-node-tests.ts",
    "test:tasks:node": "tsx scripts/run-tasks-node-tests.ts",
    "test:tasks:interoperability": "tsx projects/tasks/tests/interoperability.ts",
    "test:capstone:comparative": "tsx scripts/run-capstone-node-tests.ts comparative",
    "test:capstone:comparative:contention": "tsx scripts/run-comparative-contention.ts",
    "test:capstone:idiomatic:node": "tsx scripts/run-capstone-node-tests.ts idiomatic",
    "test:capstone:idiomatic:deno": "deno task capstone:test",
    "test:capstone:idiomatic:bun": "bun test capstones/idiomatic/tests/bun",
    "test:capstones:node": "tsx scripts/run-capstone-node-tests.ts all",
    "test:bun": "bun test lessons/15_bun_runtime exercises/15_bun_runtime capstones/idiomatic/tests/bun projects/tasks/tests/bun.test.ts",
    "test:tasks:bun": "bun test projects/tasks/tests/bun.test.ts",
    "build:bun": "bun run scripts/bun-build-smoke.ts",
    "build:tasks:bun": "bun build projects/tasks/solution/runtimes/bun/api-main.ts projects/tasks/solution/runtimes/bun/cli-main.ts --target=bun --outdir=projects/tasks/.test-data/bun-build",
    "audit:node": "npm audit --audit-level=high",
    "audit:bun": "bun audit",
    "coverage": "npm run coverage:comparative && npm run coverage:idiomatic && npm run coverage:tasks",
    "coverage:comparative": "tsx scripts/run-comparative-coverage.ts",
    "coverage:idiomatic": "tsx scripts/run-idiomatic-coverage.ts",
    "coverage:tasks": "tsx scripts/run-tasks-coverage.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck:node && npm run links && npm run course:node && npm run test:node",
    "check:tasks:node": "npm run typecheck:tasks:node && npm run test:tasks:node && npm run coverage:tasks && npm run openapi:tasks",
    "check:tasks:deno": "deno task tasks:check",
    "check:tasks:bun": "npm run typecheck:tasks:bun && npm run test:tasks:bun && npm run build:tasks:bun && npm run audit:bun",
    "check:tasks": "npm run check:tasks:node && npm run check:tasks:deno && npm run check:tasks:bun",
    "check:deno": "deno task check",
    "check:bun": "npm run typecheck:bun && npm run test:bun && npm run course:bun && npm run build:bun && npm run build:tasks:bun && npm run audit:bun"
  },
  "devDependencies": {
    "@readme/openapi-parser": "6.3.0",
    "@types/bun": "1.3.14",
    "@types/node": "24.10.0",
    "eslint": "9.39.2",
    "prettier": "3.7.4",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0"
  }
}
